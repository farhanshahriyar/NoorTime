{
  "expo": {
    "name": "NoorTime",
    "slug": "noottime",
    "version": "0.0.9",
    "orientation": "portrait",
    "icon": "./assets/images/noortime-logo.png",
    "scheme": "app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/noortime-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#050F2C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orchids.mobileappdevelopment",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NoorTime uses your location to calculate accurate prayer times and Qibla direction."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/noortime-logo.png",
        "backgroundColor": "#050F2C"
      },
      "package": "com.orchids.mobileappdevelopment"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NoorTime uses your location to calculate accurate prayer times and Qibla direction."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9b7be4b-07ae-4d11-916c-80f08d8bc9b4"
      }
    },
    "owner": "farhanshahriyarabir23s-organization"
  }
}
